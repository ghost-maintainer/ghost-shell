#!/usr/bin/env bash

set -e

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="$ROOT/.env"

if [ ! -f "$ENV_FILE" ]; then
    echo "Missing ${ENV_FILE}. Create it with API_MODEL and API_KEY."
    exit 1
fi

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

: "${API_MODEL:?Set API_MODEL in .env}"
: "${API_KEY:?Set API_KEY in .env}"

API_URL="https://integrate.api.nvidia.com/v1/chat/completions"
COMPANY_NAME="Ghost Compiler"

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[1;34m'
NC='\033[0m'

echo -e "${BLUE}Analyzing repository...${NC}"

# Verify git repository
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo "Not a Git repository."
    exit 1
}

# Stage everything except ignored files (e.g. .env)
git add -A

# Nothing to commit
if git diff --cached --quiet; then
    echo -e "${GREEN}Nothing to commit.${NC}"
    exit 0
fi

#########################################
# Collect changes
#########################################

if git rev-parse --verify HEAD >/dev/null 2>&1; then
    DIFF=$(git diff --cached --stat)
    PATCH=$(git diff --cached --unified=1)
else
    DIFF=$(git diff --cached --stat)
    PATCH=$(git diff --cached --unified=1 --no-index /dev/null . || true)
fi

# Large diffs can cause API failures; keep the prompt small.
MAX_PATCH_CHARS=6000
if [ "${#PATCH}" -gt "$MAX_PATCH_CHARS" ]; then
    PATCH="${PATCH:0:$MAX_PATCH_CHARS}

...(diff truncated)..."
fi

#########################################
# Prompt
#########################################

PROMPT=$(cat <<EOF
You are a senior software engineer at $COMPANY_NAME.

Generate ONE Conventional Commit message.

Rules:

- Maximum 8 words.
- No body.
- No explanation.
- Lowercase type.
- Use:
  feat
  fix
  refactor
  docs
  style
  chore
  perf
  test
  ci
  build

Return ONLY the commit message.

Repository changes:

$DIFF

$PATCH
EOF
)

#########################################
# Call NVIDIA API
#########################################

echo -e "${BLUE}Generating commit message...${NC}"

API_RESPONSE_FILE=$(mktemp)
trap 'rm -f "$API_RESPONSE_FILE"' EXIT

HTTP_CODE=$(
    curl -sS -o "$API_RESPONSE_FILE" -w "%{http_code}" \
        "$API_URL" \
        -H "Authorization: Bearer $API_KEY" \
        -H "Content-Type: application/json" \
        -d "$(jq -n \
            --arg model "$API_MODEL" \
            --arg prompt "$PROMPT" \
            '{
              model: $model,
              temperature: 0.2,
              max_tokens: 25,
              messages: [{ role: "user", content: $prompt }]
            }')"
)

COMMIT_MESSAGE=$(jq -r '.choices[0].message.content // empty' "$API_RESPONSE_FILE" 2>/dev/null || true)

COMMIT_MESSAGE=$(echo "$COMMIT_MESSAGE" \
    | head -n1 \
    | sed 's/^"//;s/"$//' \
    | xargs)

#########################################
# Fallback
#########################################

if [ -z "$COMMIT_MESSAGE" ] || [ "$COMMIT_MESSAGE" = "null" ]; then
    API_ERROR=$(jq -r 'if .detail then .detail elif .error.message then .error.message elif .title then .title else empty end' "$API_RESPONSE_FILE" 2>/dev/null || true)
    echo -e "${RED}Commit message API failed (HTTP ${HTTP_CODE}).${NC}" >&2
    if [ -n "$API_ERROR" ]; then
        echo -e "${RED}Reason: ${API_ERROR}${NC}" >&2
    elif [ "$HTTP_CODE" != "200" ]; then
        echo -e "${RED}Response: $(head -c 300 "$API_RESPONSE_FILE")${NC}" >&2
    fi
    echo -e "${RED}Using fallback message. Check API_KEY/API_MODEL in .env.${NC}" >&2
    COMMIT_MESSAGE="chore: update project $(date '+%Y-%m-%d %H:%M')"
fi

echo
echo -e "${GREEN}Commit:${NC} $COMMIT_MESSAGE"
echo

#########################################
# Commit
#########################################

git commit -m "$COMMIT_MESSAGE"

#########################################
# Ensure main branch
#########################################

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" != "main" ]; then
    git branch -M main
fi

#########################################
# Detect remote
#########################################

if ! git remote get-url origin >/dev/null 2>&1; then
    echo
    echo "No origin remote configured."
    echo "Add one using:"
    echo
    echo "git remote add origin <repo-url>"
    exit 1
fi

#########################################
# Push
#########################################

echo
echo -e "${BLUE}Pushing to origin/main...${NC}"

git push -u origin main

echo
echo -e "${GREEN}Done!${NC}"
