{
  "bundle": {
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "signCommand": "powershell -ExecutionPolicy Bypass -File ../../scripts/sign-windows.ps1 %1",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
