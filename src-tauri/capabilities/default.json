{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$TEMP/**" }, { "path": "$TEMP/ghost-shell-edits/**" }]
    }
  ]
}
